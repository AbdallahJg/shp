<!doctype html>
<html class="js" lang="fr">
  {%- liquid
    assign restricted_route = true

    if request.page_type == 'index'
      assign restricted_route = false
    endif

    if request.path == '/' or request.path contains '/cart' or request.path contains '/checkout'
      assign restricted_route = false
    endif
  -%}
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#f7eee9">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {%- if restricted_route -%}
      <meta name="robots" content="noindex,nofollow">
      <script>
        window.location.replace('/');
      </script>
    {%- endif -%}

    {% render 'meta-tags' %}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">

    {{ content_for_header }}

    {{ 'ibcc.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'ibcc.js' | asset_url }}" defer="defer"></script>
  </head>

  <body class="ibcc-body">
    <a class="ibcc-skip-link" href="#MainContent">Aller au contenu</a>

    <main id="MainContent" role="main">
      {%- if restricted_route -%}
        <div style="min-height:100vh;display:grid;place-items:center;padding:40px;text-align:center;">
          <p>Redirection vers l'accueil…</p>
          <noscript><p><a href="/">Retourner à l'accueil</a></p></noscript>
        </div>
      {%- else -%}
        {{ content_for_layout }}
      {%- endif -%}
    </main>
  </body>
</html>
