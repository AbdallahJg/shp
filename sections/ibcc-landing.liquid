{%- liquid
  assign price = section.settings.price | default: '34,90'
  assign compare = section.settings.compare_price | default: '59,00'
  assign buy_url = '/cart/63826733039993:1'
  assign brand = section.settings.brand_name | default: 'AÉRIS'
  assign rating = section.settings.rating | default: '4,8'
  assign review_count = section.settings.review_count | default: 2847
-%}

<div class="ibcc-page"
  data-ibcc
  data-price="{{ price }}"
  data-compare="{{ compare }}"
  data-buy-url="{{ buy_url }}"
  data-rating="{{ rating }}"
  data-review-count="{{ review_count }}">

  {%- comment %} ===== ANNOUNCEMENT BAR ===== {% endcomment -%}
  <div class="ibcc-announce">
    ✦&nbsp; {{ section.settings.announcement | default: 'Livraison express offerte sur toute commande — offre de lancement limitée' }} &nbsp;✦
  </div>

  {%- comment %} ===== HEADER ===== {% endcomment -%}
  <header class="ibcc-header" id="ibcc-header">
    <div class="ibcc-wrap ibcc-header__inner">
      <a href="#top" class="ibcc-logo">{{ brand }}<span>.</span>&nbsp;<small>Fraîcheur</small></a>
      <nav class="ibcc-nav">
        <a href="#featured-product">Le Produit</a>
        <a href="#results">En situation</a>
        <a href="#ingredients">Caractéristiques</a>
        <a href="#reviews">Avis</a>
        <a href="#faq">FAQ</a>
      </nav>
      <div class="ibcc-header__cta">
        <span class="ibcc-header__price">Dès <b>{{ price }} €</b></span>
        <a href="{{ buy_url }}" class="ibcc-btn ibcc-buy-link">Commander</a>
      </div>
    </div>
  </header>

  <span id="top"></span>

  {%- comment %} ===== HERO ===== {% endcomment -%}
  <section class="ibcc-hero">
    <div class="ibcc-wrap ibcc-hero__grid">
      <div class="ibcc-hero__copy">
        <div class="ibcc-hero__stars" data-reveal>
          <span class="ibcc-stars">★★★★★</span>
          <span>{{ rating }} / 5 · <b id="ibcc-hero-count">{{ review_count }}</b> avis vérifiés</span>
        </div>
        <h1 data-reveal data-reveal-delay="1">Gardez la tête froide,&nbsp;<em>même en pleine canicule.</em></h1>
        <p class="ibcc-hero__lead" data-reveal data-reveal-delay="2">
          La canicule frappe la France — offrez-vous une fraîcheur instantanée. Le climatiseur portable {{ brand }}
          diffuse une brise fraîche et humide par brumisation ultrasonique et rafraîchit votre espace en quelques
          secondes, même lors des journées les plus étouffantes. Sans installation, où que vous soyez.
        </p>
        <ul class="ibcc-hero__usp" data-reveal data-reveal-delay="2">
          <li>{% render 'ibcc-check' %} Refroidissement rapide : une brise fraîche &amp; humide instantanée</li>
          <li>{% render 'ibcc-check' %} 4 en 1 : ventilateur, humidificateur, purificateur &amp; diffuseur</li>
          <li>{% render 'ibcc-check' %} 100% sans fil · jusqu'à 8 h d'autonomie · spécial canicule</li>
        </ul>
        <div class="ibcc-hero__actions" data-reveal data-reveal-delay="3">
          <a href="{{ buy_url }}" class="ibcc-btn ibcc-btn--lg ibcc-buy-link">Je commande — {{ price }} €</a>
          <a href="#reviews" class="ibcc-btn ibcc-btn--ghost ibcc-btn--lg">Lire les avis</a>
        </div>
        <p class="ibcc-hero__pay">Paiement en 4× sans frais · Satisfait ou remboursé 30 jours</p>
      </div>

      <div class="ibcc-hero__media" data-reveal data-reveal-delay="2">
        <div class="ibcc-hero__media-main">
          <img src="{{ 'ibcc-hero-product.jpg' | asset_url }}" alt="Mini climatiseur portable {{ brand }}" width="900" height="900" fetchpriority="high">
        </div>
        <div class="ibcc-float-card ibcc-float-card--tl">
          <span class="dot ibcc-pulse"></span>
          <div><b id="ibcc-viewers-hero">312</b><small>personnes regardent</small></div>
        </div>
        <div class="ibcc-float-card ibcc-float-card--br">
          <span class="ibcc-stars" style="font-size:13px">★★★★★</span>
          <div><b>{{ rating }}/5</b><small>adoré par des milliers</small></div>
        </div>
      </div>
    </div>
  </section>

  {%- comment %} ===== TRUST MARQUEE ===== {% endcomment -%}
  <div class="ibcc-trust" aria-hidden="true">
    <div class="ibcc-trust__track">
      <span>Brumisation Ultrasonique&nbsp;</span><span>4 en 1&nbsp;</span><span>Jusqu'à 8 h d'Autonomie&nbsp;</span>
      <span>Réservoir 500 ml&nbsp;</span><span>Sans Gaz Réfrigérant&nbsp;</span><span>Recharge USB-C&nbsp;</span>
      <span>Brumisation Ultrasonique&nbsp;</span><span>4 en 1&nbsp;</span><span>Jusqu'à 8 h d'Autonomie&nbsp;</span>
      <span>Réservoir 500 ml&nbsp;</span><span>Sans Gaz Réfrigérant&nbsp;</span><span>Recharge USB-C&nbsp;</span>
    </div>
  </div>

  {%- comment %} ===== FEATURED PRODUCT ===== {% endcomment -%}
  <section class="ibcc-section ibcc-feature" id="featured-product">
    <div class="ibcc-wrap ibcc-feature__grid">
      <div class="ibcc-gallery" data-reveal>
        <div class="ibcc-gallery__main">
          <img id="ibcc-gallery-main" src="{{ 'ibcc-hero-product.jpg' | asset_url }}" alt="Mini climatiseur portable {{ brand }}" width="800" height="700">
        </div>
        <div class="ibcc-gallery__thumbs">
          {%- assign thumbs = 'ibcc-hero-product.jpg,ibcc-product-duo.jpg,ibcc-texture.jpg,ibcc-absorption.jpg' | split: ',' -%}
          {%- for t in thumbs -%}
            <button type="button" class="ibcc-thumb{% if forloop.first %} is-active{% endif %}" data-thumb="{{ t | asset_url }}">
              <img src="{{ t | asset_url }}" alt="Climatiseur portable {{ brand }} vue {{ forloop.index }}" loading="lazy" width="160" height="160">
            </button>
          {%- endfor -%}
        </div>
      </div>

      <div class="ibcc-buy" id="buy" data-reveal data-reveal-delay="1">
        <div class="ibcc-buy__rating">
          <span class="ibcc-stars">★★★★★</span>
          <a href="#reviews">{{ rating }} · {{ review_count }} avis</a>
        </div>
        <h2>Climatiseur Portable Haute Performance</h2>
        <p class="ibcc-buy__sub">Fraîcheur instantanée · spécial canicule</p>

        <div class="ibcc-buy__price">
          <span class="now">{{ price }} €</span>
          <span class="was">{{ compare }} €</span>
          <span class="save">-41%</span>
        </div>
        <p class="ibcc-buy__tax">TVA incluse · Livraison offerte dès 35 €</p>

        <p class="ibcc-buy__desc">
          Affrontez les fortes chaleurs en toute sérénité. Ce climatiseur portable 4 en 1 (ventilateur,
          humidificateur, purificateur et diffuseur) rafraîchit rapidement votre espace par brumisation
          ultrasonique, même lors des journées les plus étouffantes. 2 vitesses, 2 niveaux de brume et un
          réservoir de 500 ml pour 3 à 6 h de fraîcheur continue — ajoutez des glaçons pour un effet glacial immédiat.
        </p>

        <div class="ibcc-live">
          <div><span class="eye"></span> <b id="ibcc-viewers">312</b>&nbsp;personnes regardent</div>
          <div><span class="dot"></span> <b id="ibcc-sold">183</b>&nbsp;vendus ces dernières 24 h</div>
        </div>

        <div class="ibcc-buy__actions">
          <a href="{{ buy_url }}" class="ibcc-btn ibcc-btn--block ibcc-btn--lg ibcc-buy-link">Commander — {{ price }} €</a>
        </div>

        <div class="ibcc-buy__reassure">
          <div>{% render 'ibcc-check' %} Satisfait ou remboursé 30 jours</div>
          <div>{% render 'ibcc-check' %} Livraison express offerte</div>
          <div>{% render 'ibcc-check' %} Paiement sécurisé</div>
        </div>
      </div>
    </div>
  </section>

  {%- comment %} ===== WHY CHOOSE ===== {% endcomment -%}
  <section class="ibcc-section ibcc-why">
    <div class="ibcc-wrap">
      <div class="ibcc-section-head" data-reveal>
        <span class="ibcc-eyebrow">Pourquoi {{ brand }}</span>
        <h2>La vraie solution contre la canicule</h2>
        <p>Quatre raisons pour lesquelles notre climatiseur portable est devenu l'allié anti-canicule de milliers de foyers cet été.</p>
      </div>
      <div class="ibcc-why__grid">
        {%- assign why_t = 'Refroidissement Rapide|Système 4 en 1|100% Sans Fil|Silencieux & Éco' | split: '|' -%}
        {%- assign why_d = "La brumisation ultrasonique diffuse une brise fraîche et humide en quelques secondes, sans assécher l'air.|Ventilateur, humidificateur, purificateur à filtre et diffuseur d'arômes réunis dans un seul appareil compact.|Batterie 1800 mAh rechargeable en USB-C pour jusqu'à 8 h de fraîcheur, où que vous soyez.|Sans compresseur lourd ni gaz réfrigérant : un confort apaisant qui ne fait pas grimper la facture." | split: '|' -%}
        {%- for i in (0..3) -%}
          <div class="ibcc-why__card" data-reveal data-reveal-delay="{{ forloop.index }}">
            <div class="ibcc-why__icon">{% render 'ibcc-check' %}</div>
            <h3>{{ why_t[i] }}</h3>
            <p>{{ why_d[i] }}</p>
          </div>
        {%- endfor -%}
      </div>
      <div class="ibcc-why__stats">
        <div class="ibcc-stat" data-reveal><b data-count="98">0</b><span>% de clients satisfaits</span></div>
        <div class="ibcc-stat" data-reveal data-reveal-delay="1"><b data-count="8" data-suffix="h">0</b><span>d'autonomie sans fil</span></div>
        <div class="ibcc-stat" data-reveal data-reveal-delay="2"><b data-count="500" data-suffix=" ml">0</b><span>de réservoir d'eau</span></div>
        <div class="ibcc-stat" data-reveal data-reveal-delay="3"><b data-count="200000" data-suffix="+">0</b><span>clients rafraîchis</span></div>
      </div>
    </div>
  </section>

  {%- comment %} ===== EN SITUATION ===== {% endcomment -%}
  <section class="ibcc-section ibcc-results" id="results">
    <div class="ibcc-wrap">
      <div class="ibcc-section-head" data-reveal>
        <span class="ibcc-eyebrow">En situation</span>
        <h2>Au frais, partout où vous allez</h2>
        <p>Au bureau, dans la chambre ou au salon : une brise fraîche et humide à portée de main, sans installation.</p>
      </div>
      <div class="ibcc-results__grid">
        {%- assign res_img = 'ibcc-result-model.jpg|ibcc-result-light.jpg|ibcc-result-dark.jpg' | split: '|' -%}
        {%- assign res_tag = 'Au bureau|Dans la chambre|Simple à remplir' | split: '|' -%}
        {%- assign res_h = 'Fraîcheur immédiate|Des nuits apaisées|Prêt en un instant' | split: '|' -%}
        {%- assign res_p = "Posez-le sur votre bureau et profitez d'une brise fraîche personnelle, sans déranger vos voisins.|Mode silencieux et brumisation douce pour s'endormir au frais sans humidité au sol.|Remplissez le réservoir de 500 ml par le haut et ajoutez des glaçons pour un effet air conditionné immédiat." | split: '|' -%}
        {%- for i in (0..2) -%}
          <article class="ibcc-result" data-reveal data-reveal-delay="{{ forloop.index }}">
            <div class="ibcc-result__img">
              <span class="ibcc-result__tag">{{ res_tag[i] }}</span>
              <img src="{{ res_img[i] | asset_url }}" alt="Climatiseur portable {{ brand }} {{ res_tag[i] }}" loading="lazy" width="500" height="500">
            </div>
            <div class="ibcc-result__body">
              <span class="ibcc-stars">★★★★★</span>
              <h3>{{ res_h[i] }}</h3>
              <p>{{ res_p[i] }}</p>
            </div>
          </article>
        {%- endfor -%}
      </div>
      <p class="ibcc-results__note">*Les résultats peuvent varier selon la température et l'humidité ambiantes.</p>
    </div>
  </section>

  {%- comment %} ===== BENEFITS ===== {% endcomment -%}
  <section class="ibcc-section ibcc-benefits" id="benefits">
    <div class="ibcc-wrap ibcc-benefits__grid">
      <div class="ibcc-benefits__media" data-reveal>
        <img src="{{ 'ibcc-product-collage.jpg' | asset_url }}" alt="Avantages du climatiseur portable {{ brand }}" loading="lazy" width="700" height="780">
      </div>
      <div data-reveal data-reveal-delay="1">
        <span class="ibcc-eyebrow">Les Avantages</span>
        <h2 style="font-size:clamp(30px,4vw,50px)">Six raisons de l'adopter cet été</h2>
        <ul class="ibcc-benefit-list">
          {%- assign ben_h = 'Brumisation Ultrasonique|Système 4 en 1|100% Sans Fil|Réservoir 500 ml|Aromathérapie|Éco-Responsable' | split: '|' -%}
          {%- assign ben_p = "Une brise fraîche et humide instantanée, sans laisser d'eau ni d'humidité au sol.|Ventilateur (jusqu'à 2,8 m/s), humidificateur, purificateur à filtre et diffuseur d'arômes en un seul appareil.|Batterie intégrée 1800 mAh et recharge USB-C pour jusqu'à 8 h d'autonomie, dragonne incluse.|Grand réservoir étanche rempli par le haut pour 3 à 6 h de fraîcheur continue, glaçons bienvenus.|Quelques gouttes d'huiles essentielles suffisent pour transformer la pièce en zone de confort parfumée.|Sans compresseur ni gaz réfrigérant : une alternative écologique et très économe en énergie." | split: '|' -%}
          {%- for i in (0..5) -%}
            <li class="ibcc-benefit" data-reveal data-reveal-delay="{{ forloop.index | modulo: 4 }}">
              <span class="ibcc-benefit__num">0{{ forloop.index }}</span>
              <div><h3>{{ ben_h[i] }}</h3><p>{{ ben_p[i] }}</p></div>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </div>
  </section>

  {%- comment %} ===== CARACTÉRISTIQUES ===== {% endcomment -%}
  <section class="ibcc-section ibcc-ingredients" id="ingredients">
    <div class="ibcc-wrap">
      <div class="ibcc-ing__hero">
        <div class="ibcc-ing__hero-media" data-reveal>
          <img src="{{ 'ibcc-ingredients.jpg' | asset_url }}" alt="Caractéristiques du climatiseur portable {{ brand }}" loading="lazy" width="640" height="640">
        </div>
        <div data-reveal data-reveal-delay="1">
          <span class="ibcc-eyebrow">Caractéristiques</span>
          <h2>Une technologie de fraîcheur, pensée pour vous</h2>
          <p>Astuce refroidissement : ajoutez quelques glaçons dans le réservoir pour un effet "air conditionné"
             immédiat, ou versez vos huiles essentielles préférées pour une ambiance apaisante. Double puissance,
             ultra-portable, et tellement simple à utiliser.</p>
        </div>
      </div>

      <div class="ibcc-ing__grid">
        {%- assign ing_pct = '500 ml|8 h|1800 mAh' | split: '|' -%}
        {%- assign ing_h = "Réservoir d'eau|Autonomie|Batterie intégrée" | split: '|' -%}
        {%- assign ing_p = "Grand réservoir étanche, facile à remplir par le haut, pour 3 à 6 h de fraîcheur continue.|Jusqu'à 8 h de fraîcheur sans fil, parfait au bureau, en chambre ou en extérieur.|Batterie rechargeable 1800 mAh via câble USB Type-C inclus, 100% sans fil." | split: '|' -%}
        {%- for i in (0..2) -%}
          <article class="ibcc-ing-card" data-reveal data-reveal-delay="{{ forloop.index }}">
            <span class="ibcc-ing-card__pct">{{ ing_pct[i] }}</span>
            <h3>{{ ing_h[i] }}</h3>
            <p>{{ ing_p[i] }}</p>
          </article>
        {%- endfor -%}
      </div>

      <div class="ibcc-free">
        <span>Sans Gaz Réfrigérant</span><span>Sans Compresseur</span><span>Recharge USB-C</span>
        <span>2 Vitesses</span><span>2 Niveaux de Brume</span><span>Filtre Intégré</span>
      </div>
    </div>
  </section>

  {%- comment %} ===== HOW TO USE ===== {% endcomment -%}
  <section class="ibcc-section ibcc-how">
    <div class="ibcc-wrap">
      <div class="ibcc-section-head" data-reveal>
        <span class="ibcc-eyebrow">Le Mode d'Emploi</span>
        <h2>La fraîcheur en trois étapes</h2>
        <p>Aussi simple que ça : remplissez, allumez, profitez.</p>
      </div>
      <div class="ibcc-how__grid">
        {%- assign how_h = 'Remplissez|Allumez|Profitez' | split: '|' -%}
        {%- assign how_p = "Versez de l'eau dans le réservoir de 500 ml — ajoutez des glaçons pour un effet clim immédiat.|Choisissez votre vitesse de ventilation et votre niveau de brumisation à l'aide de la télécommande.|Savourez une brise fraîche et humide, à la maison comme en déplacement." | split: '|' -%}
        {%- for i in (0..2) -%}
          <div class="ibcc-how__step" data-reveal data-reveal-delay="{{ forloop.index }}">
            <div class="n">{{ forloop.index }}</div>
            <h3>{{ how_h[i] }}</h3>
            <p>{{ how_p[i] }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </section>

  {%- comment %} ===== REVIEWS ===== {% endcomment -%}
  <section class="ibcc-section ibcc-reviews" id="reviews">
    <div class="ibcc-wrap">
      <div class="ibcc-section-head" data-reveal>
        <span class="ibcc-eyebrow">Adoré &amp; Noté</span>
        <h2>{{ review_count }}+ raisons de rester au frais</h2>
        <p>Des avis authentiques de clients qui ont fait de ce rafraîchisseur d'air leur indispensable de l'été.</p>
      </div>

      <div class="ibcc-reviews__summary" data-reveal>
        <div class="ibcc-reviews__score">
          <div class="big">{{ rating }}</div>
          <div class="ibcc-stars">★★★★★</div>
          <small>Sur la base de <span id="ibcc-total-count">{{ review_count }}</span> avis</small>
        </div>
        <div class="ibcc-bars">
          {%- assign bar_pct = '92|6|1|1|0' | split: '|' -%}
          {%- assign stars_lbl = '5,4,3,2,1' | split: ',' -%}
          {%- for i in (0..4) -%}
            <div class="ibcc-bar">
              <span>{{ stars_lbl[i] }} ★</span>
              <span class="ibcc-bar__track"><span class="ibcc-bar__fill" data-fill="{{ bar_pct[i] }}"></span></span>
              <span>{{ bar_pct[i] }}%</span>
            </div>
          {%- endfor -%}
        </div>
      </div>

      <div class="ibcc-reviews__bar" data-reveal>
        <div class="ibcc-reviews__filters" id="ibcc-filters">
          <button class="ibcc-chip is-active" data-filter="all">Tous les avis</button>
          <button class="ibcc-chip" data-filter="photo">Avec photos</button>
          <button class="ibcc-chip" data-filter="5">5 étoiles</button>
          <button class="ibcc-chip" data-filter="4">4 étoiles</button>
        </div>
        <button class="ibcc-btn ibcc-btn--ghost" id="ibcc-open-reviews">Voir les {{ review_count }} avis</button>
      </div>

      <div class="ibcc-reviews__grid" id="ibcc-reviews-grid"></div>

      <div class="ibcc-reviews__more">
        <button class="ibcc-btn ibcc-btn--lg" id="ibcc-open-reviews-2">Lire les {{ review_count }} avis</button>
      </div>
    </div>
  </section>

  {%- comment %} ===== REVIEWS MODAL ===== {% endcomment -%}
  <div class="ibcc-modal" id="ibcc-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Tous les avis clients">
    <div class="ibcc-modal__overlay" data-close></div>
    <div class="ibcc-modal__panel">
      <div class="ibcc-modal__head">
        <div>
          <h3>Avis clients</h3>
          <div class="ibcc-stars">★★★★★ <small>{{ rating }} · {{ review_count }} avis</small></div>
        </div>
        <button class="ibcc-modal__close" data-close aria-label="Fermer les avis">✕</button>
      </div>
      <div class="ibcc-modal__filters" id="ibcc-modal-filters">
        <button class="ibcc-chip is-active" data-filter="all">Tous</button>
        <button class="ibcc-chip" data-filter="photo">Avec photos</button>
        <button class="ibcc-chip" data-filter="5">5 étoiles</button>
        <button class="ibcc-chip" data-filter="4">4 étoiles</button>
        <button class="ibcc-chip" data-filter="3">3 étoiles</button>
      </div>
      <div class="ibcc-modal__body" id="ibcc-modal-body">
        <div class="ibcc-modal__sentinel" id="ibcc-modal-sentinel"></div>
        <div class="ibcc-modal__loading" id="ibcc-modal-loading">Chargement d'autres avis…</div>
      </div>
    </div>
  </div>

  {%- comment %} ===== FAQ ===== {% endcomment -%}
  <section class="ibcc-section ibcc-faq" id="faq">
    <div class="ibcc-wrap">
      <div class="ibcc-section-head" data-reveal>
        <span class="ibcc-eyebrow">Bon à savoir</span>
        <h2>Vos questions, nos réponses</h2>
      </div>
      <div class="ibcc-faq__wrap">
        {%- assign faq_q = "Est-ce un vrai climatiseur ?|Comment fonctionne le refroidissement ?|Quelle est l'autonomie de la batterie ?|Est-il bruyant ?|Y a-t-il de l'humidité au sol ?|Quelle est votre garantie ?" | split: '|' -%}
        {%- assign faq_a = "C'est un rafraîchisseur d'air personnel 4 en 1 (ventilateur, humidificateur, purificateur et diffuseur). Sans compresseur ni gaz réfrigérant, il rafraîchit efficacement votre zone de confort de façon écologique.|Il diffuse une brise fraîche et humide par brumisation ultrasonique. Ajoutez des glaçons dans le réservoir de 500 ml pour un effet air conditionné immédiat.|Grâce à sa batterie intégrée 1800 mAh, jusqu'à 8 h d'autonomie. Rechargez-le facilement avec le câble USB Type-C inclus.|Non. Il reste discret, surtout en basse vitesse — idéal pour travailler ou s'endormir au frais.|Non. La brumisation ultrasonique ne laisse ni eau ni humidité au sol, contrairement aux solutions classiques.|Satisfait ou remboursé pendant 30 jours. Si la fraîcheur n'est pas au rendez-vous, contactez-nous pour un remboursement intégral." | split: '|' -%}
        {%- for i in (0..5) -%}
          <div class="ibcc-acc" data-reveal>
            <button type="button" class="ibcc-acc__q">{{ faq_q[i] }} <span class="ic">+</span></button>
            <div class="ibcc-acc__a"><div class="ibcc-acc__a-inner">{{ faq_a[i] }}</div></div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </section>

  {%- comment %} ===== NEWSLETTER ===== {% endcomment -%}
  <section class="ibcc-section ibcc-news">
    <div class="ibcc-wrap">
      <div class="ibcc-news__card" data-reveal>
        <span class="ibcc-eyebrow">Rejoignez la communauté</span>
        <h2>-10% sur votre première commande</h2>
        <p>Soyez les premiers informés des réassorts, astuces anti-chaleur et offres réservées aux membres. Pas de spam, que de la fraîcheur.</p>
        <form class="ibcc-news__form" id="ibcc-news-form">
          <input type="email" name="email" placeholder="Votre adresse e-mail" required aria-label="Adresse e-mail">
          <button type="submit" class="ibcc-btn">Obtenir -10%</button>
        </form>
        <div class="ibcc-news__msg" id="ibcc-news-msg" role="status"></div>
        <p class="ibcc-news__fine">En vous inscrivant, vous acceptez de recevoir les e-mails marketing de {{ brand }}.</p>
      </div>
    </div>
  </section>

  {%- comment %} ===== FOOTER ===== {% endcomment -%}
  <footer class="ibcc-footer">
    <div class="ibcc-wrap">
      <div class="ibcc-footer__grid">
        <div>
          <div class="ibcc-footer__logo">{{ brand }}<span>.</span></div>
          <p>La fraîcheur portable, pensée pour braver la chaleur où que vous soyez. Un appareil malin, un confort sans compromis.</p>
        </div>
        <div>
          <h4>Explorer</h4>
          <ul>
            <li><a href="#featured-product">Le Produit</a></li>
            <li><a href="#ingredients">Caractéristiques</a></li>
            <li><a href="#results">En situation</a></li>
            <li><a href="#reviews">Avis</a></li>
          </ul>
        </div>
        <div>
          <h4>Aide</h4>
          <ul>
            <li><a href="#faq">FAQ</a></li>
            <li><a href="#">Livraison</a></li>
            <li><a href="#">Retours &amp; Garantie 30 jours</a></li>
            <li><a href="#">Nous contacter</a></li>
          </ul>
        </div>
        <div>
          <h4>Nos engagements</h4>
          <ul>
            <li>Sans gaz réfrigérant</li>
            <li>Écologique &amp; économe</li>
            <li>Recharge USB-C</li>
            <li>Livraison express offerte</li>
          </ul>
        </div>
      </div>
      <div class="ibcc-footer__bottom">
        <span>© {{ 'now' | date: '%Y' }} {{ brand }}. Tous droits réservés.</span>
        <div class="pays"><span>VISA</span><span>MASTERCARD</span><span>AMEX</span><span>PAYPAL</span><span>SHOP PAY</span></div>
      </div>
    </div>
  </footer>

  {%- comment %} ===== STICKY MOBILE BUY BAR ===== {% endcomment -%}
  <div class="ibcc-stickybuy" id="ibcc-stickybuy">
    <div class="ibcc-stickybuy__info">
      <b>{{ price }} €</b>
      <small><span class="ibcc-stars" style="font-size:11px">★★★★★</span> {{ rating }}</small>
    </div>
    <a href="{{ buy_url }}" class="ibcc-btn ibcc-buy-link">Commander</a>
  </div>

  {%- comment %} ===== SOCIAL PROOF TOAST ===== {% endcomment -%}
  <div class="ibcc-toast" id="ibcc-toast" role="status" aria-live="polite">
    <img id="ibcc-toast-img" src="{{ 'ibcc-hero-product.jpg' | asset_url }}" alt="">
    <div>
      <b id="ibcc-toast-name">Quelqu'un</b>
      <small id="ibcc-toast-text">vient de commander le climatiseur</small>
    </div>
    <span class="check">✓</span>
  </div>
</div>

{%- comment %} ===== DATA FOR JS ===== {% endcomment -%}
<script>
  window.IBCC = {
    price: {{ price | json }},
    compare: {{ compare | json }},
    rating: {{ rating | json }},
    reviewCount: {{ review_count | json }},
    reviewPhotos: [
      {%- for i in (1..18) -%}
        {{ 'ibcc-review-' | append: i | append: '.jpg' | asset_url | json }}{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ],
    productImg: {{ 'ibcc-hero-product.jpg' | asset_url | json }}
  };
</script>

{% schema %}
{
  "name": "AERIS Landing",
  "settings": [
    { "type": "header", "content": "Marque & Prix" },
    { "type": "text", "id": "brand_name", "label": "Nom de la marque", "default": "AÉRIS" },
    { "type": "text", "id": "price", "label": "Prix promo (texte)", "default": "34,90" },
    { "type": "text", "id": "compare_price", "label": "Prix barré", "default": "59,00" },
    { "type": "text", "id": "rating", "label": "Note moyenne", "default": "4,8" },
    { "type": "number", "id": "review_count", "label": "Nombre d'avis", "default": 2847 },
    { "type": "text", "id": "announcement", "label": "Texte de la barre d'annonce", "default": "Livraison express offerte sur toute commande — offre de lancement limitée" }
  ],
  "presets": [{ "name": "AERIS Landing" }]
}
{% endschema %}
